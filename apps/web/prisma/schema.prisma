generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String             @id @default(cuid())
  createdAt              DateTime           @default(now())
  updatedAt              DateTime           @updatedAt
  email                  String             @unique
  name                   String?
  image                  String?
  password               String?
  role                   Role               @default(CLIENT)
  accounts               Account[]
  activities             Activity[]
  auditLogs              AuditLog[]         @relation("UserAuditLogs")
  adminOverrides         AdminOverride[]    @relation("AdminOverrideActor")
  calendarAccounts       CalendarAccount[]
  assignedChecklistItems ChecklistItem[]
  depositsAsClient       Deposit[]          @relation("DepositClient")
  createdEvents          Event[]
  eventSharesAsCreator   EventShare[]       @relation("EventShareCreatedBy")
  eventSharesAsViewer    EventShare[]       @relation("EventShareViewer")
  addedEventStakeholders EventStakeholder[] @relation("EventStakeholderAddedBy")
  eventStakeholders      EventStakeholder[] @relation("EventStakeholderUser")
  memberships            Membership[]
  notifications          Notification[]
  ownedOrgs              Organization[]     @relation("OrganizationOwner")
  paymentIntentsAsPayee  PaymentIntent[]    @relation("PaymentIntentPayee")
  paymentIntentsAsPayer  PaymentIntent[]    @relation("PaymentIntentPayer")
  reviews                Review[]
  sessions               Session[]
  assignedTasks          Task[]
  transactionsAsPayee    Transaction[]      @relation("TransactionPayee")
  transactionsAsPayer    Transaction[]      @relation("TransactionPayer")
  userFeatureFlags       UserFeatureFlag[]
  userSettings           UserSettings?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id                String           @id @default(cuid())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  name              String
  slug              String           @unique
  type              OrgType          @default(PLANNER)
  ownerId           String
  about             String?
  addressLine1      String?
  addressLine2      String?
  availabilityJson  Json?
  city              String?
  contactEmail      String?
  contactPhone      String?
  country           String?          @default("US")
  facebook          String?
  instagram         String?
  mediaJson         Json?
  notificationsJson Json?
  paymentsJson      Json?
  postalCode        String?
  profileStatus     String?
  servicesJson      Json?
  spacesJson        Json?
  stripeConnectAccountId String?     @unique
  state             String?
  website           String?
  activities        Activity[]
  auditLogs         AuditLog[]
  bookingRequests   BookingRequest[]
  calendarEvents    CalendarEvent[]
  contracts         Contract[]
  deposits          Deposit[]
  disputes          Dispute[]
  escrowAccounts    EscrowAccount[]
  events            Event[]
  invites           Invite[]
  listings          Listing[]
  members           Membership[]
  notifications     Notification[]
  orgFeatureFlags   OrgFeatureFlag[]
  settings          OrgSettings?
  owner             User             @relation("OrganizationOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  payouts           Payout[]
  proposals         Proposal[]
  refundRequests    RefundRequest[]
  teams             Team[]
  threads           Thread[]
}

model Team {
  id      String       @id @default(cuid())
  name    String
  orgId   String
  members Membership[]
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Membership {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  teamId    String?
  role      OrgRole      @default(MEMBER)
  staffRole StaffRole?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team      Team?        @relation(fields: [teamId], references: [id])
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, orgId])
}

model Invite {
  id        String       @id @default(cuid())
  orgId     String
  email     String
  role      OrgRole      @default(MEMBER)
  expiresAt DateTime
  token     String       @unique
  accepted  Boolean      @default(false)
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  locale          String   @default("en-US")
  timezone        String   @default("America/Chicago")
  currency        String   @default("USD")
  marketingEmails Boolean  @default(true)
  smsAlerts       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model OrgSettings {
  id           String       @id @default(cuid())
  orgId        String       @unique
  locale       String       @default("en-US")
  timezone     String       @default("America/Chicago")
  currency     String       @default("USD")
  legalEntity  String?
  billingEmail String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  org          Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model FeatureFlag {
  key       String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  enabled   Boolean  @default(false)
  rule      Json?
}

model UserFeatureFlag {
  id      String  @id @default(cuid())
  userId  String
  key     String
  enabled Boolean @default(false)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
}

model OrgFeatureFlag {
  id      String       @id @default(cuid())
  orgId   String
  key     String
  enabled Boolean      @default(false)
  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, key])
}

model AuditLog {
  id       String        @id @default(cuid())
  at       DateTime      @default(now())
  actorId  String?
  orgId    String?
  ip       String?
  action   String
  target   String?
  metadata Json?
  actor    User?         @relation("UserAuditLogs", fields: [actorId], references: [id])
  org      Organization? @relation(fields: [orgId], references: [id])

  @@index([orgId, at])
}

model AdminOverride {
  id                    String                     @id @default(cuid())
  createdAt             DateTime                   @default(now())
  actorId               String
  actorRole             Role
  orgId                 String?
  targetType            AdminOverrideTargetType
  targetId              String
  bookingClassification BookingClassification?
  feeProfileSnapshot    Json?
  acceptanceCaptureId   String?
  exceptionType         AdminOverrideExceptionType
  decision              AdminOverrideDecision
  authorityPath         String
  reason                String
  refundRequestId       String?
  disputeId             String?
  paymentHoldbackId     String?
  payoutId              String?
  paymentIntentId       String?
  contractId            String?
  proposalId            String?
  milestoneId           String?
  auditLogId            String                     @unique
  metadata              Json?
  actor                 User                       @relation("AdminOverrideActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, createdAt])
  @@index([proposalId, createdAt])
  @@index([paymentIntentId, createdAt])
  @@index([refundRequestId, createdAt])
  @@index([disputeId, createdAt])
  @@index([paymentHoldbackId, createdAt])
  @@index([payoutId, createdAt])
}

model AcceptanceCapture {
  id                 String   @id @default(cuid())
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  actorId            String
  actorRole          String
  orgId              String?
  bookingClassification String
  feeProfileSnapshot Json
  legalSurface       String
  legalVersion       String
  acceptedAt         DateTime
  sourceSurface      String
  requestContextId   String?
  proposalId         String?
  contractId         String?
  paymentIntentId    String?
  adminOverrideId    String?
  metadata           Json?

  @@index([proposalId, acceptedAt])
  @@index([contractId, acceptedAt])
  @@index([paymentIntentId, acceptedAt])
  @@index([adminOverrideId, acceptedAt])
  @@index([actorId, acceptedAt])
}

model Event {
  id                 String             @id @default(cuid())
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  orgId              String
  createdById        String
  name               String
  slug               String             @unique
  type               EventType
  objective          String?
  description        String?
  startAt            DateTime
  endAt              DateTime
  venueCity          String?
  venueState         String?
  venueCountry       String?            @default("US")
  guestTarget        Int?
  status             EventStatus        @default(PLANNING)
  budgetCents        Int                @default(0)
  eventTypeRaw       String?
  eventTypeCanonical String?
  budgetRaw          String?
  budgetMin          Int?
  budgetMax          Int?
  budgetCurrency     String?            @db.VarChar(3)
  activities         Activity[]
  bookingRequests    BookingRequest[]
  budgetLines        BudgetLine[]
  calendarEvents     CalendarEvent[]
  checklists         Checklist[]
  contracts          Contract[]
  deposits           Deposit[]
  disputes           Dispute[]
  escrowAccounts     EscrowAccount[]
  createdBy          User               @relation(fields: [createdById], references: [id])
  org                Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  shares             EventShare[]
  stakeholders       EventStakeholder[]
  guestLists         GuestList?
  invitations        Invitation[]
  media              Media[]
  milestones         Milestone[]
  proposals          Proposal[]
  seatingPlans       SeatingPlan?
  shortlistItems     ShortlistItem[]
  tasks              Task[]
  threads            Thread[]
}

model ShortlistItem {
  id        String   @id @default(cuid())
  eventId   String
  createdAt DateTime @default(now())
  listingId String
  notes     String?
  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([eventId, listingId])
  @@index([eventId])
}

model EventStakeholder {
  id            String               @id @default(cuid())
  eventId       String
  userId        String
  role          EventStakeholderRole
  addedByUserId String
  createdAt     DateTime             @default(now())
  addedBy       User                 @relation("EventStakeholderAddedBy", fields: [addedByUserId], references: [id])
  event         Event                @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user          User                 @relation("EventStakeholderUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventShare {
  id              String          @id @default(cuid())
  eventId         String
  viewerUserId    String
  scope           EventShareScope @default(SUMMARY)
  createdByUserId String
  createdAt       DateTime        @default(now())
  createdBy       User            @relation("EventShareCreatedBy", fields: [createdByUserId], references: [id])
  event           Event           @relation(fields: [eventId], references: [id], onDelete: Cascade)
  viewer          User            @relation("EventShareViewer", fields: [viewerUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, viewerUserId, scope])
  @@index([eventId])
  @@index([viewerUserId])
}

model Milestone {
  id      String   @id @default(cuid())
  eventId String
  title   String
  dueAt   DateTime
  done    Boolean  @default(false)
  order   Int      @default(0)
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model ChecklistTemplate {
  id         String      @id @default(cuid())
  orgId      String?
  title      String
  type       EventType?
  items      Json
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  checklists Checklist[]
}

model Checklist {
  id         String             @id @default(cuid())
  eventId    String
  title      String
  templateId String?
  event      Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  template   ChecklistTemplate? @relation(fields: [templateId], references: [id])
  items      ChecklistItem[]
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  title       String
  description String?
  assigneeId  String?
  dueAt       DateTime?
  done        Boolean   @default(false)
  order       Int       @default(0)
  assignee    User?     @relation(fields: [assigneeId], references: [id])
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Task {
  id          String       @id @default(cuid())
  eventId     String
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  dueAt       DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  assignee    User?        @relation(fields: [assigneeId], references: [id])
  event       Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model BudgetLine {
  id           String         @id @default(cuid())
  eventId      String
  category     BudgetCategory
  label        String
  plannedCents Int            @default(0)
  actualCents  Int            @default(0)
  vendorName   String?
  notes        String?
  event        Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model Activity {
  id      String       @id @default(cuid())
  at      DateTime     @default(now())
  orgId   String
  eventId String?
  actorId String?
  action  String
  target  String?
  meta    Json?
  actor   User?        @relation(fields: [actorId], references: [id])
  event   Event?       @relation(fields: [eventId], references: [id])
  org     Organization @relation(fields: [orgId], references: [id])

  @@index([orgId, at])
}

model Notification {
  id        String       @id @default(cuid())
  userId    String
  orgId     String
  type      String
  title     String
  body      String?
  read      Boolean      @default(false)
  link      String?
  createdAt DateTime     @default(now())
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Listing {
  id              String             @id @default(cuid())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  orgId           String
  slug            String             @unique
  title           String
  type            ListingType
  category        ListingCategory
  description     String?
  website         String?
  phone           String?
  email           String?
  minGuests       Int?
  maxGuests       Int?
  priceTier       Int?
  street          String?
  city            String?
  state           String?
  country         String?            @default("US")
  postalCode      String?
  latitude        Float?
  longitude       Float?
  coverImageUrl   String?
  ratingAvg       Float              @default(0)
  ratingCount     Int                @default(0)
  availSlots      AvailabilitySlot[]
  bookingRequests BookingRequest[]
  org             Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tags            ListingTag[]
  gallery         Media[]
  offers          Offer[]
  proposals       Proposal[]
  reviews         Review[]
  shortlistItems  ShortlistItem[]
  threads         Thread[]
}

model ListingTag {
  id        String  @id @default(cuid())
  listingId String
  value     String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([value])
}

model Media {
  id        String   @id @default(cuid())
  listingId String?
  eventId   String?
  url       String
  caption   String?
  createdAt DateTime @default(now())
  event     Event?   @relation(fields: [eventId], references: [id])
  listing   Listing? @relation(fields: [listingId], references: [id])
}

model AvailabilitySlot {
  id        String             @id @default(cuid())
  listingId String
  startAt   DateTime
  endAt     DateTime
  status    AvailabilityStatus @default(AVAILABLE)
  note      String?
  listing   Listing            @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId, startAt, endAt])
}

model Offer {
  id          String  @id @default(cuid())
  listingId   String
  name        String
  description String?
  priceCents  Int?
  unit        String?
  listing     Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model BookingRequest {
  id           String        @id @default(cuid())
  createdAt    DateTime      @default(now())
  orgId        String
  eventId      String
  listingId    String
  contactName  String
  contactEmail String
  contactPhone String?
  startAt      DateTime
  endAt        DateTime
  guests       Int?
  message      String?
  status       BookingStatus @default(PENDING)
  quoteCents   Int?
  notes        String?
  event        Event         @relation(fields: [eventId], references: [id])
  listing      Listing       @relation(fields: [listingId], references: [id])
  org          Organization  @relation(fields: [orgId], references: [id])

  @@index([listingId, createdAt])
}

model Review {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  authorId  String
  listingId String
  rating    Int
  title     String?
  body      String?
  flagged   Boolean  @default(false)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId])
}

model Proposal {
  id                    String                @id @default(cuid())
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  orgId                 String
  eventId               String
  listingId             String?
  title                 String
  summary               String?
  status                ProposalStatus        @default(DRAFT)
  bookingClassification BookingClassification @default(DIRECT)
  currency              String                @default("USD")
  subtotalCents Int                @default(0)
  taxCents      Int                @default(0)
  totalCents    Int                @default(0)
  validUntil    DateTime?
  terms         String?
  contract      Contract?
  disputes      Dispute[]
  escrowAccount EscrowAccount?
  milestones    PaymentMilestone[]
  payouts       Payout[]
  refundRequests RefundRequest[]
  event         Event              @relation(fields: [eventId], references: [id])
  listing       Listing?           @relation(fields: [listingId], references: [id])
  org           Organization       @relation(fields: [orgId], references: [id])
  lineItems     ProposalLineItem[]
  sections      ProposalSection[]
  threads       Thread[]
}

model ProposalLineItem {
  id             String   @id @default(cuid())
  proposalId     String
  label          String
  description    String?
  qty            Float    @default(1)
  unit           String?
  unitPriceCents Int      @default(0)
  totalCents     Int      @default(0)
  proposal       Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model PaymentMilestone {
  id             String           @id @default(cuid())
  proposalId     String
  title          String
  description    String?
  dueType        MilestoneDueType
  dueDate        DateTime?
  dueOffsetDays  Int?
  amountCents    Int
  status         MilestoneStatus  @default(PENDING)
  paymentIntents PaymentIntent[]
  refundRequests RefundRequest[]
  proposal       Proposal         @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model ProposalSection {
  id         String   @id @default(cuid())
  proposalId String
  heading    String
  body       String
  order      Int      @default(0)
  proposal   Proposal @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, order])
}

model Contract {
  id                 String          @id @default(cuid())
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  proposalId         String          @unique
  orgId              String
  eventId            String
  title              String
  bodyMd             String
  version            Int             @default(1)
  status             ContractStatus  @default(OUT_FOR_SIGNATURE)
  buyerId            String?
  platformFeePercent Float           @default(5.0)
  sellerId           String?
  changeOrders       ChangeOrder[]
  event              Event           @relation(fields: [eventId], references: [id])
  org                Organization    @relation(fields: [orgId], references: [id])
  proposal           Proposal        @relation(fields: [proposalId], references: [id])
  paymentIntents     PaymentIntent[]
  refundRequests     RefundRequest[]
  signatures         Signature[]
}

model Signature {
  id          String    @id @default(cuid())
  contractId  String
  signerId    String?
  signerName  String
  signerEmail String
  ip          String?
  ua          String?
  signedAt    DateTime?
  method      String?
  imageUrl    String?
  contract    Contract  @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model ChangeOrder {
  id         String            @id @default(cuid())
  contractId String
  number     Int
  title      String
  bodyMd     String
  deltaCents Int               @default(0)
  status     ChangeOrderStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  approvedAt DateTime?
  contract   Contract          @relation(fields: [contractId], references: [id], onDelete: Cascade)
}

model EscrowAccount {
  id           String       @id @default(cuid())
  orgId        String
  eventId      String
  proposalId   String       @unique
  stripeIntent String?      @unique
  status       EscrowStatus @default(OPEN)
  balanceCents Int          @default(0)
  currency     String       @default("USD")
  event        Event        @relation(fields: [eventId], references: [id])
  org          Organization @relation(fields: [orgId], references: [id])
  proposal     Proposal     @relation(fields: [proposalId], references: [id])
}

model Payout {
  id             String       @id @default(cuid())
  proposalId     String
  milestoneId    String?      @unique
  listingId      String?
  orgId          String
  amountCents    Int
  stripeTransfer String?
  status         PayoutStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [orgId], references: [id])
  proposal       Proposal     @relation(fields: [proposalId], references: [id], onDelete: Cascade)
}

model MoneyTx {
  id          String   @id @default(cuid())
  at          DateTime @default(now())
  type        String
  proposalId  String?
  milestoneId String?
  amountCents Int
  currency    String   @default("USD")
  stripeId    String?  @unique
  meta        Json?
}

model WebhookEvent {
  id             String   @id @default(cuid())
  eventId        String   @unique
  type           String
  stripeIntentId String?
  processedAt    DateTime?
  meta           Json?
}

model PaymentIntent {
  id             String              @id @default(cuid())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  contractId     String
  milestoneId    String?
  payerId        String
  payeeId        String
  amountCents    Int
  currency       String              @default("USD")
  status         PaymentIntentStatus @default(REQUIRES_PAYMENT)
  fundedAt       DateTime?
  stripeIntentId String?             @unique
  paymentMethod  String?
  contract       Contract            @relation(fields: [contractId], references: [id], onDelete: Cascade)
  milestone      PaymentMilestone?   @relation(fields: [milestoneId], references: [id])
  refundRequests RefundRequest[]
  payee          User                @relation("PaymentIntentPayee", fields: [payeeId], references: [id])
  payer          User                @relation("PaymentIntentPayer", fields: [payerId], references: [id])
  transactions   Transaction?
}

model Transaction {
  id               String        @id @default(cuid())
  createdAt        DateTime      @default(now())
  paymentIntentId  String        @unique
  payerId          String
  payeeId          String
  netAmountCents   Int
  platformFeeCents Int
  totalAmountCents Int
  currency         String        @default("USD")
  stripeChargeId   String?       @unique
  processedAt      DateTime?
  payee            User          @relation("TransactionPayee", fields: [payeeId], references: [id])
  payer            User          @relation("TransactionPayer", fields: [payerId], references: [id])
  paymentIntent    PaymentIntent @relation(fields: [paymentIntentId], references: [id], onDelete: Cascade)
}

model PaymentHoldback {
  id                        String                @id @default(cuid())
  createdAt                 DateTime              @default(now())
  updatedAt                 DateTime              @updatedAt
  paymentIntentId           String                @unique
  proposalId                String
  contractId                String?
  milestoneId               String?
  bookingClassification     BookingClassification
  feeProfileSnapshot        Json
  acceptanceCaptureId       String?
  highRiskTriggers          Json
  triggerSummary            String?
  state                     HoldbackState         @default(NONE)
  reason                    String?
  holdbackAmountCents       Int?
  holdbackPercent           Float?
  actorAdminId              String?
  actorAdminRole            String?
  manualRiskFlag            Boolean               @default(false)
  adminDecision             HoldbackDecision?
  adminDecisionAt           DateTime?
  adminDecisionById         String?
  adminDecisionByRole       String?
  adminDecisionReason       String?
  releasedAt                DateTime?
  releasedById              String?
  releasedByRole            String?
  releaseReason             String?
  auditTrail                Json?

  @@index([proposalId, createdAt])
  @@index([milestoneId, state])
  @@index([contractId, state])
  @@index([state, updatedAt])
}

model Deposit {
  id                    String        @id @default(cuid())
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  eventId               String
  clientUserId          String
  proOrgId              String
  amountCents           Int
  currency              String        @default("USD")
  status                DepositStatus @default(PENDING)
  stripePaymentIntentId String?       @unique
  stripeChargeId        String?
  notes                 String?
  clientUser            User          @relation("DepositClient", fields: [clientUserId], references: [id])
  event                 Event         @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proOrg                Organization  @relation(fields: [proOrgId], references: [id])

  @@index([eventId])
  @@index([clientUserId])
  @@index([proOrgId])
  @@index([status])
}

model Thread {
  id           String              @id @default(cuid())
  createdAt    DateTime            @default(now())
  orgId        String
  eventId      String?
  proposalId   String?
  listingId    String?
  subject      String
  messages     Message[]
  event        Event?              @relation(fields: [eventId], references: [id])
  listing      Listing?            @relation(fields: [listingId], references: [id])
  org          Organization        @relation(fields: [orgId], references: [id])
  proposal     Proposal?           @relation(fields: [proposalId], references: [id])
  participants ThreadParticipant[]
}

model ThreadParticipant {
  id       String  @id @default(cuid())
  threadId String
  userId   String?
  email    String
  roleHint String?
  thread   Thread  @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Message {
  id          String   @id @default(cuid())
  threadId    String
  senderId    String?
  bodyMd      String
  attachments Json?
  createdAt   DateTime @default(now())
  thread      Thread   @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model Dispute {
  id                  String             @id @default(cuid())
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  orgId               String
  eventId             String?
  proposalId          String
  contractId          String?
  paymentIntentId     String?
  milestoneId         String?
  linkedRefundRequestId String?
  actorId             String
  actorRole           String
  bookingClassification BookingClassification
  feeProfileSnapshot  Json
  acceptanceCaptureId String?
  requestContextId    String?
  title               String
  body                String?
  disputeReason       String
  status              DisputeStatus      @default(OPEN)
  freezeState         DisputeFreezeState @default(FROZEN)
  resolutionType      DisputeResolutionType?
  resolution          String?
  adminDecisionAt     DateTime?
  adminDecisionById   String?
  adminDecisionReason String?
  auditTrail          Json?
  event               Event?             @relation(fields: [eventId], references: [id])
  org                 Organization       @relation(fields: [orgId], references: [id])
  proposal            Proposal           @relation(fields: [proposalId], references: [id])

  @@index([proposalId, status, createdAt])
  @@index([milestoneId, status])
  @@index([linkedRefundRequestId])
  @@index([contractId, status])
  @@index([paymentIntentId, status])
}

model RefundRequest {
  id                     String              @id @default(cuid())
  createdAt              DateTime            @default(now())
  updatedAt              DateTime            @updatedAt
  orgId                  String
  actorId                String
  actorRole              String
  proposalId             String
  contractId             String?
  paymentIntentId        String?
  milestoneId            String?
  acceptanceCaptureId    String?
  bookingClassification  BookingClassification
  feeProfileSnapshot     Json
  amountRequestedCents   Int
  currency               String              @default("USD")
  reason                 String
  processingFeeTreatment RefundFeeTreatment  @default(BUYER_ABSORBS)
  platformFeeTreatment   RefundFeeTreatment  @default(NON_REFUNDABLE)
  status                 RefundRequestStatus @default(OPEN)
  requestContextId       String?
  adminDecisionAt        DateTime?
  adminDecisionById      String?
  adminDecisionReason    String?
  auditTrail             Json?
  contract               Contract?           @relation(fields: [contractId], references: [id])
  milestone              PaymentMilestone?   @relation(fields: [milestoneId], references: [id])
  org                    Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  paymentIntent          PaymentIntent?      @relation(fields: [paymentIntentId], references: [id])
  proposal               Proposal            @relation(fields: [proposalId], references: [id], onDelete: Cascade)

  @@index([proposalId, status, createdAt])
  @@index([paymentIntentId, status])
  @@index([milestoneId, status])
  @@index([contractId, status])
}

model CalendarAccount {
  id               String             @id @default(cuid())
  userId           String
  provider         String
  email            String
  accessToken      String?
  refreshToken     String?
  expiresAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  googleCalendarId String?
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  mappings         CalendarMapping[]
  syncState        CalendarSyncState?

  @@unique([userId, provider])
}

model CalendarMapping {
  id                String          @id @default(cuid())
  userId            String
  calendarAccountId String
  entityType        String
  entityId          String
  googleEventId     String
  googleCalendarId  String
  lastSyncedAt      DateTime        @default(now())
  calendarAccount   CalendarAccount @relation(fields: [calendarAccountId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
  @@index([googleEventId])
}

model CalendarSyncState {
  id                String          @id @default(cuid())
  userId            String          @unique
  calendarAccountId String          @unique
  googleCalendarId  String
  syncMode          String          @default("one-way")
  watchResourceId   String?
  watchChannelId    String?
  watchExpiration   DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  calendarAccount   CalendarAccount @relation(fields: [calendarAccountId], references: [id], onDelete: Cascade)
}

model CalendarEvent {
  id          String       @id @default(cuid())
  orgId       String
  eventId     String?
  title       String
  description String?
  startAt     DateTime
  endAt       DateTime
  allDay      Boolean      @default(false)
  location    String?
  source      String?
  visibility  String?
  createdById String?
  event       Event?       @relation(fields: [eventId], references: [id])
  org         Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model GuestList {
  id      String       @id @default(cuid())
  eventId String       @unique
  title   String       @default("Guest List")
  invited Int          @default(0)
  rsvped  Int          @default(0)
  guests  Guest[]
  groups  GuestGroup[]
  event   Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

model GuestGroup {
  id          String    @id @default(cuid())
  guestListId String
  name        String
  notes       String?
  guests      Guest[]
  guestList   GuestList @relation(fields: [guestListId], references: [id], onDelete: Cascade)
}

model Guest {
  id          String      @id @default(cuid())
  guestListId String
  groupId     String?
  firstName   String
  lastName    String
  email       String?
  phone       String?
  side        String?
  plusOnes    Int         @default(0)
  tags        Json?
  status      RSVPStatus  @default(PENDING)
  dietary     String?
  notes       String?
  seatId      String?     @unique
  group       GuestGroup? @relation(fields: [groupId], references: [id])
  guestList   GuestList   @relation(fields: [guestListId], references: [id], onDelete: Cascade)
  seat        Seat?       @relation(fields: [seatId], references: [id])
  invitations Invitation?

  @@index([email])
}

model Invitation {
  id            String    @id @default(cuid())
  eventId       String
  guestId       String    @unique
  token         String    @unique
  sentAt        DateTime?
  respondedAt   DateTime?
  channel       String?
  invitationUrl String?
  event         Event     @relation(fields: [eventId], references: [id], onDelete: Cascade)
  guest         Guest     @relation(fields: [guestId], references: [id], onDelete: Cascade)
}

model SeatingPlan {
  id      String  @id @default(cuid())
  eventId String  @unique
  title   String  @default("Main Floor")
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  tables  Table[]
}

model Table {
  id            String      @id @default(cuid())
  seatingPlanId String
  name          String
  capacity      Int
  x             Int         @default(0)
  y             Int         @default(0)
  seats         Seat[]
  seatingPlan   SeatingPlan @relation(fields: [seatingPlanId], references: [id], onDelete: Cascade)
}

model Seat {
  id      String @id @default(cuid())
  tableId String
  number  Int
  guest   Guest?
  table   Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
}

model MetricDaily {
  date         DateTime @id
  orgCount     Int      @default(0)
  userCount    Int      @default(0)
  eventsCount  Int      @default(0)
  gmvInCents   Int      @default(0)
  payoutsCents Int      @default(0)
}

model AbuseReport {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  reporterId String?
  targetType String
  targetId   String
  reason     String
  status     String   @default("OPEN")
  notes      String?
}

